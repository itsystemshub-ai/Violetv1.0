{
  "name": "erp-zenith",
  "version": "2.0.0",
  "description": "ERP ZENITH - Sistema Empresarial Completo",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "cd apps/backend && npm run dev",
    "dev:frontend": "cd apps/frontend && npm run dev",
    "build": "npm run build:backend && npm run build:frontend",
    "build:backend": "cd apps/backend && npm run build",
    "build:frontend": "cd apps/frontend && npm run build",
    "start": "cd apps/backend && npm start",
    "install:all": "npm install && cd apps/backend && npm install && cd ../../apps/frontend && npm install"
  },
  "keywords": ["erp", "zenith", "venezuela", "enterprise"],
  "author": "ERP ZENITH Team",
  "license": "PROPRIETARY",
  "devDependencies": {
    "concurrently": "^9.2.1"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
