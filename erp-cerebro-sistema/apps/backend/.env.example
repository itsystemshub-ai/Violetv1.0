# ERP ZENITH Backend - Environment Variables

# Server
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/erp_zenith?schema=public

# JWT
JWT_SECRET=erp-zenith-super-secret-jwt-key-min-64-characters-change-in-production-2026
JWT_EXPIRES_IN=24h
JWT_REFRESH_SECRET=erp-zenith-super-secret-refresh-key-min-64-characters-change-in-production-2026
JWT_REFRESH_EXPIRES_IN=7d

# Bcrypt
BCRYPT_ROUNDS=10

# Session
SESSION_SECRET=erp-zenith-session-secret-change-in-production
SESSION_TIMEOUT=480

# MFA
MFA_ISSUER=ERP-ZENITH
MFA_WINDOW=1

# Rate Limiting
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

# CORS
CORS_ORIGIN=http://localhost:5173
CORS_CREDENTIALS=true

# Logs
LOG_LEVEL=debug
LOG_FILE=./logs/app.log

# IA APIs (Optional)
GEMINI_API_KEY=
HF_TOKEN=
GROQ_API_KEY=
