# =============================================================================
# VIOLET ERP - Configuración de Base de Datos Firebird
# =============================================================================

# -----------------------------------------------------------------------------
# CONEXIÓN A FIREBIRD SQL
# -----------------------------------------------------------------------------

# Servidor Firebird
FIREBIRD_HOST=localhost
FIREBIRD_PORT=3050

# Credenciales
FIREBIRD_USER=SYSDBA
FIREBIRD_PASSWORD=masterkey

# Ruta de la base de datos
FIREBIRD_DATABASE=C:\\VIOLET_ERP\\VIOLET3.FDB

# O usar alias (configurar en aliases.conf)
# FIREBIRD_DATABASE=violet

# -----------------------------------------------------------------------------
# POOL DE CONEXIONES
# -----------------------------------------------------------------------------

# Tamaño del pool de conexiones
FIREBIRD_POOL_SIZE=10

# Tiempo de espera de conexión (segundos)
FIREBIRD_CONNECTION_TIMEOUT=30

# Tiempo de vida de conexión inactiva (segundos)
FIREBIRD_IDLE_TIMEOUT=300

# -----------------------------------------------------------------------------
# CONFIGURACIÓN DE TRANSACCIONES
# -----------------------------------------------------------------------------

# Aislamiento de transacción
# Opciones: READ_COMMITTED, REPEATABLE_READ, SERIALIZABLE
FIREBIRD_ISOLATION_LEVEL=READ_COMMITTED

# Modo de lectura/escritura
FIREBIRD_READ_WRITE=READ WRITE

# Modo de espera de bloqueo
FIREBIRD_LOCK_MODE=WAIT

# Tiempo de espera de bloqueo (segundos)
FIREBIRD_LOCK_TIMEOUT=10

# -----------------------------------------------------------------------------
# CONFIGURACIÓN DE CHARACTER SET
# -----------------------------------------------------------------------------

# Character set (UTF8 recomendado)
FIREBIRD_CHARSET=UTF8

# Collation
FIREBIRD_COLLATION=UNICODE_CI_AI

# -----------------------------------------------------------------------------
# CONFIGURACIÓN DE PAGE SIZE
# -----------------------------------------------------------------------------

# Page size (16384 recomendado para Firebird 2.5+)
FIREBIRD_PAGE_SIZE=16384

# -----------------------------------------------------------------------------
# CONFIGURACIÓN DE BACKUP
# -----------------------------------------------------------------------------

# Ruta de backups
FIREBIRD_BACKUP_PATH=C:\\VIOLET_ERP\\BACKUPS\\

# Frecuencia de backup automático (días)
FIREBIRD_BACKUP_FREQUENCY=7

# Mantener últimos N backups
FIREBIRD_BACKUP_KEEP=4

# -----------------------------------------------------------------------------
# CONFIGURACIÓN DE LOGGING
# -----------------------------------------------------------------------------

# Habilitar logging de consultas SQL
FIREBIRD_LOG_SQL=false

# Habilitar logging de errores
FIREBIRD_LOG_ERRORS=true

# Ruta de logs
FIREBIRD_LOG_PATH=C:\\VIOLET_ERP\\LOGS\\

# -----------------------------------------------------------------------------
# CONFIGURACIÓN DE SEGURIDAD
# -----------------------------------------------------------------------------

# Habilitar encriptación de conexión (WireCrypt)
FIREBIRD_WIRE_CRYPT=Enabled

# Servidores de autenticación
FIREBIRD_AUTH_SERVER=Srp,Win_Sspi

# Cliente de autenticación
FIREBIRD_AUTH_CLIENT=Srp

# -----------------------------------------------------------------------------
# CONFIGURACIÓN DE RED
# -----------------------------------------------------------------------------

# Direcciones IP permitidas (comma-separated)
# Dejar vacío para permitir todas
FIREBIRD_REMOTE_ADDRESS=

# Habilitar acceso remoto
FIREBIRD_REMOTE_ACCESS=true

# -----------------------------------------------------------------------------
# CONFIGURACIÓN DE CACHE
# -----------------------------------------------------------------------------

# Tamaño de cache de páginas (default: 2048)
FIREBIRD_DEFAULT_DB_CACHE_PAGES=2048

# Tamaño máximo de bloque sin flush (default: 32)
FIREBIRD_MAX_UNFLUSHED_WRITES=32

# -----------------------------------------------------------------------------
# CONFIGURACIÓN DE TEMPORALES
# -----------------------------------------------------------------------------

# Tamaño de bloque temporal (MB)
FIREBIRD_TEMP_BLOCK_SIZE=1024

# Ruta de archivos temporales
FIREBIRD_TEMP_DIRECTORY=C:\\VIOLET_ERP\\TEMP\\

# -----------------------------------------------------------------------------
# CONFIGURACIÓN DE MONITOREO
# -----------------------------------------------------------------------------

# Habilitar tablas de monitoreo
FIREBIRD_ENABLE_MONITOR=true

# Intervalo de monitoreo (segundos)
FIREBIRD_MONITOR_INTERVAL=60

# -----------------------------------------------------------------------------
# CONFIGURACIÓN DE AUDITORÍA
# -----------------------------------------------------------------------------

# Habilitar auditoría de consultas
FIREBIRD_ENABLE_AUDIT=false

# Tablas a auditar (comma-separated)
# Dejar vacío para auditar todas
FIREBIRD_AUDIT_TABLES=CLIENTES,PROVEEDORES,VENTAS,COMPRAS,BANCOS,CAJA,NOMINA,ASIENTOS_CONTABLES

# Acciones a auditar (INSERT, UPDATE, DELETE)
FIREBIRD_AUDIT_ACTIONS=INSERT,UPDATE,DELETE

# -----------------------------------------------------------------------------
# VARIABLES DE ENTORNO PARA LA APLICACIÓN
# -----------------------------------------------------------------------------

# URL de conexión completa (para aplicaciones)
DATABASE_URL=firebird://SYSDBA:masterkey@localhost:3050/C:\\VIOLET_ERP\\VIOLET3.FDB?charset=UTF8

# Driver a usar
DATABASE_DRIVER=firebird

# -----------------------------------------------------------------------------
# CONFIGURACIÓN PARA DESARROLLO
# -----------------------------------------------------------------------------

# En desarrollo, usar base de datos local
DEV_FIREBIRD_DATABASE=C:\\VIOLET_ERP\\VIOLET_DEV.FDB
DEV_FIREBIRD_USER=DEV_USER
DEV_FIREBIRD_PASSWORD=DevPassword2026!

# -----------------------------------------------------------------------------
# CONFIGURACIÓN PARA PRODUCCIÓN
# -----------------------------------------------------------------------------

# En producción, usar servidor remoto
PROD_FIREBIRD_HOST=192.168.1.100
PROD_FIREBIRD_PORT=3050
PROD_FIREBIRD_DATABASE=192.168.1.100:VIOLET
PROD_FIREBIRD_USER=VIOLET_APP
PROD_FIREBIRD_PASSWORD=ProdPasswordSeguro!2026#XYZ

# -----------------------------------------------------------------------------
# CONFIGURACIÓN PARA STAGING
# -----------------------------------------------------------------------------

STAGING_FIREBIRD_HOST=localhost
STAGING_FIREBIRD_PORT=3050
STAGING_FIREBIRD_DATABASE=C:\\VIOLET_ERP\\VIOLET_STAGING.FDB
STAGING_FIREBIRD_USER=SYSDBA
STAGING_FIREBIRD_PASSWORD=masterkey

# -----------------------------------------------------------------------------
# FIN DE CONFIGURACIÓN
# -----------------------------------------------------------------------------
