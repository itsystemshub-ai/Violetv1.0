{
  "name": "@violet-erp/types",
  "version": "1.0.0",
  "description": "Violet ERP - Tipos TypeScript compartidos",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
