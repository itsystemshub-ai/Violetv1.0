# Violet ERP Frontend - Variables de Entorno Ejemplo

VITE_APP_NAME=Violet ERP
VITE_APP_VERSION=2.0.0

# API URLs
VITE_API_URL=http://localhost:3000/api
VITE_WS_URL=ws://localhost:3001

# Modo Híbrido
VITE_HYBRID_MODE=local
VITE_AUTO_SYNC=true
VITE_SYNC_INTERVAL=15000
VITE_SYNC_MAX_RETRIES=5

# Características
VITE_FEATURE_DARK_MODE=true
VITE_FEATURE_NOTIFICATIONS=true
VITE_FEATURE_REALTIME=true
VITE_FEATURE_OFFLINE_MODE=true

# Locale
VITE_APP_LOCALE=es-DO
VITE_APP_TIMEZONE=America/Santo_Domingo
