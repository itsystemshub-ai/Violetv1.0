# =============================================================================
# VIOLET ERP MONOREPO - .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# DEPENDENCIES
# -----------------------------------------------------------------------------
node_modules/
**/node_modules/
jspm_packages/

# -----------------------------------------------------------------------------
# PACKAGE MANAGER CACHES
# -----------------------------------------------------------------------------
.npm/
.pnpm-store/
.pnpm-debug.log*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
bun-debug.log*

# -----------------------------------------------------------------------------
# LOGS & DIAGNOSTICS
# -----------------------------------------------------------------------------
logs/
*.log
report.[0-9]*.json

# -----------------------------------------------------------------------------
# RUNTIME DATA / PIDS
# -----------------------------------------------------------------------------
pids/
*.pid
*.seed
*.pid.lock

# -----------------------------------------------------------------------------
# ENV FILES (KEEP EXAMPLES)
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example
!.env.*.example
!.env.local.example
.env.local
.env.development
.env.staging
.env.production

# -----------------------------------------------------------------------------
# COVERAGE & TESTING
# -----------------------------------------------------------------------------
coverage/
.nyc_output/
*.lcov
test-results/
playwright-report/
cypress/videos/
cypress/screenshots/
cypress/downloads/

# -----------------------------------------------------------------------------
# BUILD OUTPUTS / CACHES
# -----------------------------------------------------------------------------
dist/
**/dist/
build/
**/build/
electron-dist/
dist-electron/
**/dist-electron/
out/
bin/
.tmp/
tmp/
temp/
.cache/
.esbuild/
.esbuild-cache/
.parcel-cache/
.rpt2_cache/
.rts2_cache_cjs/
.rts2_cache_es/
.rts2_cache_umd/
.vite/
.vite-inspect/
.turbo/

# -----------------------------------------------------------------------------
# TYPESCRIPT
# -----------------------------------------------------------------------------
*.tsbuildinfo
**/*.tsbuildinfo

# -----------------------------------------------------------------------------
# WEB FRAMEWORKS
# -----------------------------------------------------------------------------
.next/
.nuxt/
.svelte-kit/
.storybook-out/
storybook-static/
.angular/
.docusaurus/
.vercel/
.netlify/
.output/

# -----------------------------------------------------------------------------
# EDITORS & OS
# -----------------------------------------------------------------------------
.vscode/*
!.vscode/extensions.json
!.vscode/tasks.json
.idea/
*.iml
.vs/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
.node_repl_history

# -----------------------------------------------------------------------------
# LINTING
# -----------------------------------------------------------------------------
.eslintcache

# -----------------------------------------------------------------------------
# UPLOADED FILES
# -----------------------------------------------------------------------------
uploaded_files/

# -----------------------------------------------------------------------------
# BACKUP FILES
# -----------------------------------------------------------------------------
*.bak
*.backup
*.old

# -----------------------------------------------------------------------------
# ELECTRON BUILDER
# -----------------------------------------------------------------------------
release/
**/release/

# -----------------------------------------------------------------------------
# DATABASE FILES (LOCAL)
# -----------------------------------------------------------------------------
*.db
*.sqlite
*.sqlite3
!database/**/*.sql

# -----------------------------------------------------------------------------
# MONOREPO SPECIFIC
# -----------------------------------------------------------------------------
# Keep workspace-specific ignores in each app/package
apps/*/coverage/
apps/*/dist/
packages/*/dist/
