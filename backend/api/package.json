{
  "name": "@violet-erp/backend",
  "version": "2.0.0",
  "description": "Violet ERP - Backend API Avanzado con Firebird",
  "private": true,
  "type": "module",
  "main": "./src/server.js",
  "scripts": {
    "dev": "nodemon --exec node src/server.js",
    "start": "node src/server.js",
    "start:prod": "pm2 start ecosystem.config.cjs --env production",
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run --config vitest.integration.config.js",
    "lint": "eslint src --ext .js,.ts",
    "lint:fix": "eslint src --ext .js,.ts --fix",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist logs",
    "db:init": "node scripts/init-firebird.js",
    "db:migrate": "node scripts/migrate.js",
    "db:seed": "node scripts/seed.js",
    "db:backup": "node scripts/backup.js",
    "db:restore": "node scripts/restore.js"
  },
  "dependencies": {
    "node-firebird": "^1.0.10",
    "express": "^5.2.1",
    "cors": "^2.8.6",
    "helmet": "^7.1.0",
    "compression": "^1.7.4",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "dotenv": "^16.3.1",
    "jsonwebtoken": "^9.0.3",
    "bcrypt": "^6.0.0",
    "uuid": "^11.0.5",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "winston": "^3.11.0",
    "winston-daily-rotate-file": "^5.0.0",
    "morgan": "^1.10.0",
    "zod": "^3.25.76",
    "cache-manager": "^6.0.0",
    "cache-manager-redis-store": "^3.0.1",
    "node-cron": "^3.0.3",
    "pm2": "^5.4.0",
    "multer": "^1.4.5-lts.1",
    "express-fileupload": "^1.4.3",
    "nodemailer": "^6.9.7",
    "handlebars": "^4.7.8",
    "pdfkit": "^0.15.0",
    "xlsx": "^0.18.5",
    "redis": "^4.6.11",
    "node-cache": "^5.1.2"
  },
  "devDependencies": {
    "@types/node": "^22.5.5",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.19",
    "@types/compression": "^1.7.5",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.11",
    "@types/nodemailer": "^6.4.14",
    "@types/pdfkit": "^0.13.4",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/parser": "^8.0.1",
    "@typescript-eslint/eslint-plugin": "^8.0.1",
    "eslint": "^9.9.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "nodemon": "^3.0.1",
    "rimraf": "^6.0.1",
    "typescript": "^5.5.3",
    "vitest": "^4.0.18",
    "@vitest/coverage-v8": "^4.0.18",
    "supertest": "^7.0.0",
    "@types/supertest": "^6.0.2"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
