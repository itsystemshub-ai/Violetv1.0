{
  "name": "@violet-erp/backend",
  "version": "1.0.0",
  "description": "Violet ERP - Backend API con Firebird",
  "private": true,
  "type": "module",
  "main": "./src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "start:prod": "pm2 start ecosystem.config.cjs --env production",
    "dev": "nodemon src/server.js",
    "db:init": "node scripts/init-database.js",
    "db:backup": "node scripts/backup-database.js",
    "db:restore": "node scripts/restore-database.js",
    "lint": "eslint src --ext .js",
    "clean": "rimraf dist logs"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "compression": "^1.7.4",
    "cors": "^2.8.6",
    "dotenv": "^16.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.3",
    "node-firebird": "^1.0.10",
    "pm2": "^5.4.0",
    "socket.io": "^4.8.3",
    "uuid": "^13.0.0",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "eslint": "^9.9.0",
    "nodemon": "^3.0.1",
    "rimraf": "^6.0.1"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
