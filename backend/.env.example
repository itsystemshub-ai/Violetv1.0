# Backend Environment Variables

# Server Configuration
NODE_ENV=development
PORT=3001
HOST=0.0.0.0

# CORS Configuration
CORS_ORIGIN=http://localhost:5173,http://localhost:5174

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-min-64-characters-long-change-in-production
JWT_EXPIRES_IN=24h
JWT_REFRESH_SECRET=your-super-secret-refresh-key-min-64-characters-long-change-in-production
JWT_REFRESH_EXPIRES_IN=7d

# Bcrypt Configuration
BCRYPT_ROUNDS=12

# Database Configuration
DB_PATH=./data/violet.db

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info
LOG_FILE=./logs/app.log

# SSL/TLS (Production)
SSL_ENABLED=false
SSL_KEY_PATH=./ssl/private.key
SSL_CERT_PATH=./ssl/certificate.crt

# Admin User (First Run)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=Violet@2026!
ADMIN_EMAIL=admin@violet-erp.com
