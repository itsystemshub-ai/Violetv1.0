{
  "name": "violet-erp",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"npm run dev:vite\" \"npm run proxy\"",
    "dev:vite": "vite",
    "dev:host": "vite --host",
    "dev:full": "concurrently -k \"npm run dev\" \"npm run proxy\"",
    "proxy": "cd server && npm install && npm start",
    "build": "npm run clean && tsc && vite build",
    "build:staging": "npm run clean && node scripts/fix-case-netlify.js && tsc && vite build --mode staging",
    "build:production": "npm run clean && node scripts/fix-case-netlify.js && tsc && npm rebuild || true && vite build --mode production",
    "clean": "node -e \"const fs = require('fs'); ['dist', 'dist-electron'].forEach(d => fs.rmSync(d, { recursive: true, force: true }))\"",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest watch",
    "migrate:passwords": "tsx scripts/migrate-passwords.ts",
    "migrate:modules": "tsx scripts/migrate-to-modules.ts",
    "validate:deps": "tsx scripts/validate-dependencies.ts",
    "generate:exports": "tsx scripts/generate-barrel-exports.ts",
    "electron:start": "wait-on http://localhost:8080 && electron .",
    "electron:dev": "concurrently -k \"npm run dev\" \"npm run electron:start\"",
    "electron:dev:full": "concurrently -k \"npm run dev\" \"npm run proxy\" \"npm run electron:start\"",
    "electron:build": "npm run clean && npm run build && electron-builder",
    "electron:dist": "npm run clean && npm run build && node scripts/fix-electron-html.cjs && electron-builder --win",
    "release": "npm run electron:dist",
    "vercel-build": "node scripts/fix-case-netlify.js && npm run build:production"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hookform/resolvers": "^3.9.0",
    "@iconify/react": "^6.0.2",
    "@radix-ui/react-accordion": "^1.2.0",
    "@radix-ui/react-alert-dialog": "^1.1.1",
    "@radix-ui/react-aspect-ratio": "^1.1.0",
    "@radix-ui/react-avatar": "^1.1.0",
    "@radix-ui/react-checkbox": "^1.1.1",
    "@radix-ui/react-collapsible": "^1.1.0",
    "@radix-ui/react-context-menu": "^2.2.1",
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-dropdown-menu": "^2.1.1",
    "@radix-ui/react-hover-card": "^1.1.1",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-menubar": "^1.1.1",
    "@radix-ui/react-navigation-menu": "^1.2.0",
    "@radix-ui/react-popover": "^1.1.1",
    "@radix-ui/react-progress": "^1.1.0",
    "@radix-ui/react-radio-group": "^1.2.0",
    "@radix-ui/react-scroll-area": "^1.1.0",
    "@radix-ui/react-select": "^2.1.1",
    "@radix-ui/react-separator": "^1.1.0",
    "@radix-ui/react-slider": "^1.2.0",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-switch": "^1.1.0",
    "@radix-ui/react-tabs": "^1.1.0",
    "@radix-ui/react-toast": "^1.2.1",
    "@radix-ui/react-toggle": "^1.1.0",
    "@radix-ui/react-toggle-group": "^1.1.0",
    "@radix-ui/react-tooltip": "^1.1.4",
    "@sentry/react": "^10.40.0",
    "@supabase/supabase-js": "^2.55.0",
    "@tanstack/react-query": "^5.56.2",
    "@types/crypto-js": "^4.2.2",
    "@types/react-window": "^1.8.8",
    "axios": "^1.13.2",
    "better-sqlite3": "^12.6.2",
    "bootstrap": "^5.3.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.0.0",
    "cors": "^2.8.6",
    "crypto-js": "^4.2.0",
    "date-fns": "^3.6.0",
    "dexie": "^4.3.0",
    "electron-is-dev": "^3.0.1",
    "electron-updater": "^6.8.3",
    "embla-carousel-react": "^8.3.0",
    "express": "^5.2.1",
    "framer-motion": "^11.15.0",
    "input-otp": "^1.2.4",
    "jspdf": "^4.2.0",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^0.462.0",
    "next-themes": "^0.3.0",
    "postgres": "^3.4.8",
    "react": "^18.3.1",
    "react-day-picker": "^8.10.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.53.0",
    "react-icons": "^5.4.0",
    "react-resizable-panels": "^2.1.3",
    "react-router-dom": "^6.26.2",
    "react-window": "^2.2.7",
    "recharts": "^2.12.7",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "sonner": "^1.5.0",
    "tailwind-merge": "^2.5.2",
    "tw-animate-css": "^1.4.0",
    "vaul": "^0.9.3",
    "xlsx": "^0.18.5",
    "zod": "^3.25.76",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@babel/generator": "^7.28.0",
    "@babel/parser": "^7.28.0",
    "@babel/traverse": "^7.28.0",
    "@babel/types": "^7.28.0",
    "@eslint/js": "^9.9.0",
    "@sentry/vite-plugin": "^5.1.1",
    "@tailwindcss/postcss": "^4.0.0",
    "@tailwindcss/vite": "^4.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.5.5",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitejs/plugin-react-swc": "^3.5.0",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "bcrypt": "^6.0.0",
    "concurrently": "^9.2.1",
    "electron": "^40.6.1",
    "electron-builder": "^26.8.1",
    "eslint": "^9.9.0",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.9",
    "glob": "^13.0.6",
    "globals": "^15.9.0",
    "happy-dom": "^20.7.0",
    "jsdom": "^28.1.0",
    "jsonwebtoken": "^9.0.3",
    "lovable-tagger": "1.1.13",
    "postcss": "^8.4.47",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.0.1",
    "vite": "^6.1.7",
    "vitest": "^4.0.18",
    "wait-on": "^9.0.4"
  },
  "main": "electron/main.cjs",
  "build": {
    "appId": "com.violet.erp",
    "productName": "Violet ERP",
    "copyright": "Copyright © 2026 Violet ERP",
    "directories": {
      "output": "dist-electron",
      "buildResources": "electron"
    },
    "files": [
      "electron/**/*",
      "!electron/db.cjs",
      "!backend/**/*"
    ],
    "extraResources": [
      {
        "from": "dist",
        "to": "dist",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "artifactName": "${productName}-Setup-${version}.${ext}"
    },
    "nsis": {
      "include": "electron/installer.nsh",
      "oneClick": true,
      "perMachine": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": false,
      "runAfterFinish": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Violet ERP"
    }
  }
}
