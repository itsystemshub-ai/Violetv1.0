{
  "name": "violet-erp-monorepo",
  "private": true,
  "version": "1.0.0",
  "description": "Violet ERP - Next Generation Enterprise Resource Planning",
  "author": "Violet ERP Team",
  "license": "UNLICENSED",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -k \"npm run dev:web\" \"npm run dev:server\"",
    "dev:web": "npm run dev -w @violet/web",
    "dev:server": "npm run dev -w @violet/server",
    "dev:electron": "npm run dev -w @violet/electron",
    "dev:all": "concurrently -k \"npm run dev:web\" \"npm run dev:server\" \"npm run dev:electron\"",
    "build": "npm run build:packages && npm run build:web",
    "build:packages": "npm run build -w @violet/types && npm run build -w @violet/utils && npm run build -w @violet/config",
    "build:web": "npm run build -w @violet/web",
    "build:server": "npm run build -w @violet/server",
    "build:electron": "npm run build -w @violet/electron",
    "build:all": "npm run build:packages && npm run build:web && npm run build:server && npm run build:electron",
    "test": "npm run test -w @violet/web",
    "test:run": "npm run test:run -w @violet/web",
    "lint": "npm run lint -w @violet/web",
    "lint:fix": "npm run lint:fix -w @violet/web",
    "typecheck": "npm run typecheck -w @violet/web",
    "clean": "npm run clean -w @violet/electron",
    "install:all": "npm install"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "typescript": "^5.5.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/violet-erp.git"
  },
  "keywords": [
    "erp",
    "enterprise",
    "resource-planning",
    "venezuela",
    "react",
    "electron",
    "typescript"
  ]
}
