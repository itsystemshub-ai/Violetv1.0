{
  "name": "violet-erp-monorepo",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "pnpm run --parallel dev",
    "dev:web": "pnpm --filter @violet-erp/web dev",
    "dev:api": "pnpm --filter @violet-erp/api dev",
    "build": "pnpm run --parallel build",
    "build:web": "pnpm --filter @violet-erp/web build",
    "build:api": "pnpm --filter @violet-erp/api build",
    "lint": "pnpm run --parallel lint",
    "lint:fix": "pnpm run --parallel lint:fix",
    "typecheck": "pnpm run --parallel typecheck",
    "test": "pnpm run --parallel test",
    "clean": "pnpm run --parallel clean",
    "clean:all": "rimraf **/node_modules **/dist **/.turbo",
    "deps:install": "pnpm install",
    "deps:update": "pnpm update -r",
    "deps:outdated": "pnpm outdated -r"
  },
  "devDependencies": {
    "rimraf": "^6.0.1"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.0.0"
  }
}
