{
  "name": "violet-erp",
  "version": "1.0.0",
  "description": "Violet ERP - Sistema Empresarial con Firebird",
  "private": true,
  "scripts": {
    "dev": "concurrently \"pnpm dev:backend\" \"pnpm dev:frontend\"",
    "dev:backend": "cd backend/api && npm run dev",
    "dev:frontend": "cd frontend/web && npm run dev",
    "build": "pnpm build:backend && pnpm build:frontend",
    "build:backend": "cd backend/api && npm run build",
    "build:frontend": "cd frontend/web && npm run build",
    "start": "cd backend/api && npm start",
    "db:init": "cd database/firebird && node -e \"console.log('Firebird schema ready')\"",
    "install:all": "pnpm install && cd backend/api && npm install && cd ../../frontend/web && npm install"
  },
  "keywords": ["erp", "violet", "firebird", "enterprise"],
  "author": "Violet ERP Team",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^9.2.1"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
