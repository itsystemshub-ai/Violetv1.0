# =============================================================================
# VIOLET ERP - Configuración Híbrida (Local + Nube)
# =============================================================================

# -----------------------------------------------------------------------------
# APLICACIÓN
# -----------------------------------------------------------------------------
NODE_ENV=development
APP_NAME=Violet ERP
APP_VERSION=1.0.0
APP_URL=http://localhost:5173
API_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# SERVIDOR (Backend)
# -----------------------------------------------------------------------------
PORT=3000
HOST=localhost
CORS_ORIGIN=http://localhost:5173

# -----------------------------------------------------------------------------
# AUTENTICACIÓN JWT
# -----------------------------------------------------------------------------
JWT_SECRET=violet-erp-super-secret-jwt-key-change-in-production-2024
JWT_EXPIRES_IN=1h
JWT_REFRESH_SECRET=violet-erp-refresh-secret-change-in-production-2024
JWT_REFRESH_EXPIRES_IN=7d

# -----------------------------------------------------------------------------
# ARQUITECTURA HÍBRIDA
# -----------------------------------------------------------------------------
# Modo: local, cloud, both
HYBRID_MODE=both

# Sincronización
SYNC_ENABLED=true
SYNC_INTERVAL=30000
SYNC_BATCH_SIZE=100

# Resolución de conflictos: cloud-wins, local-wins, manual
CONFLICT_RESOLUTION=cloud-wins

# Offline
OFFLINE_MODE=false
OFFLINE_QUEUE_MAX=1000

# -----------------------------------------------------------------------------
# BASE DE DATOS LOCAL (SQLite)
# -----------------------------------------------------------------------------
DB_TYPE=sqlite
SQLITE_PATH=./violet.db

# -----------------------------------------------------------------------------
# BASE DE DATOS NUBE (PostgreSQL / Supabase)
# -----------------------------------------------------------------------------
# PostgreSQL (Producción)
DATABASE_URL=postgresql://usuario:password@localhost:5432/violet_erp

# Supabase (Alternativa)
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_KEY=tu-anon-key

# -----------------------------------------------------------------------------
# API CLOUD PARA SINCRONIZACIÓN
# -----------------------------------------------------------------------------
CLOUD_API_URL=https://api.violet-erp.com
CLOUD_WS_URL=wss://ws.violet-erp.com
CLOUD_API_KEY=tu-cloud-api-key
CLOUD_INSTANCE_ID=unique-instance-id

# -----------------------------------------------------------------------------
# WEBSOCKETS / SOCKET.IO
# -----------------------------------------------------------------------------
WS_ENABLED=true
WS_PORT=3001

# -----------------------------------------------------------------------------
# REDIS (Opcional - Para caché y sesiones compartidas)
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379
REDIS_ENABLED=false

# -----------------------------------------------------------------------------
# CORREO ELECTRÓNICO
# -----------------------------------------------------------------------------
MAIL_ENABLED=false
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=tu-email@gmail.com
MAIL_PASSWORD=tu-app-password
MAIL_FROM=Violet ERP <noreply@violet-erp.com>
MAIL_SECURE=false

# -----------------------------------------------------------------------------
# ALMACENAMIENTO DE ARCHIVOS
# -----------------------------------------------------------------------------
UPLOAD_PATH=./uploads
MAX_UPLOAD_SIZE=10485760
ALLOWED_EXTENSIONS=jpg,jpeg,png,pdf,xlsx,xls,csv,doc,docx

# -----------------------------------------------------------------------------
# SENTRY (Monitoreo de Errores)
# -----------------------------------------------------------------------------
SENTRY_DSN=https://tu-dsn@sentry.io/proyecto
SENTRY_ENVIRONMENT=development

# -----------------------------------------------------------------------------
# LOGS
# -----------------------------------------------------------------------------
LOG_LEVEL=debug
LOG_FILE=./logs/app.log

# -----------------------------------------------------------------------------
# SEGURIDAD
# -----------------------------------------------------------------------------
BCRYPT_ROUNDS=10
SESSION_SECRET=violet-session-secret-change-in-production
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# -----------------------------------------------------------------------------
# CARACTERÍSTICAS OPCIONALES
# -----------------------------------------------------------------------------
FEATURE_EMAIL_VERIFICATION=false
FEATURE_TWO_FACTOR_AUTH=false
FEATURE_SOCIAL_LOGIN=false
FEATURE_FILE_STORAGE_LOCAL=true
FEATURE_FILE_STORAGE_S3=false

# -----------------------------------------------------------------------------
# AWS S3 (Para almacenamiento de archivos)
# -----------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=violet-erp-files

# -----------------------------------------------------------------------------
# STRIPE (Pagos)
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# -----------------------------------------------------------------------------
# FRONTEND (Vite)
# -----------------------------------------------------------------------------
VITE_APP_NAME=Violet ERP
VITE_API_URL=http://localhost:3000/api
VITE_WS_URL=http://localhost:3001
VITE_CLOUD_API_URL=https://api.violet-erp.com
VITE_APP_VERSION=1.0.0

# -----------------------------------------------------------------------------
# CARACTERÍSTICAS DEL FRONTEND
# -----------------------------------------------------------------------------
VITE_FEATURE_DARK_MODE=true
VITE_FEATURE_NOTIFICATIONS=true
VITE_FEATURE_REAL_TIME=true
VITE_FEATURE_OFFLINE_MODE=true

# -----------------------------------------------------------------------------
# BACKUP AUTOMÁTICO
# -----------------------------------------------------------------------------
BACKUP_ENABLED=true
BACKUP_INTERVAL=86400000
BACKUP_RETENTION=10

# -----------------------------------------------------------------------------
# PM2 CONFIG
# -----------------------------------------------------------------------------
PM2_INSTANCES=max
PM2_MAX_MEMORY=1G
