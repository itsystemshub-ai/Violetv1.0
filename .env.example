# =============================================================================
# VIOLET ERP - Variables de Entorno Avanzadas
# =============================================================================

# -----------------------------------------------------------------------------
# APLICACIÓN
# -----------------------------------------------------------------------------
NODE_ENV=development
APP_NAME=Violet ERP
APP_VERSION=2.0.0
APP_URL=http://localhost:5173
API_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# SERVIDOR
# -----------------------------------------------------------------------------
PORT=3000
HOST=0.0.0.0
CORS_ORIGIN=http://localhost:5173
CORS_CREDENTIALS=true

# -----------------------------------------------------------------------------
# FIREBIRD DATABASE
# -----------------------------------------------------------------------------
FIREBIRD_HOST=localhost
FIREBIRD_PORT=3050
FIREBIRD_DATABASE=C:/VioletERP/database/valery3.fdb
FIREBIRD_USER=SYSDBA
FIREBIRD_PASSWORD=masterkey
FIREBIRD_ROLE=RDB$ADMIN
FIREBIRD_PAGE_SIZE=4096

# Pool de conexiones
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_POOL_ACQUIRE_TIMEOUT=5000
DB_POOL_IDLE_TIMEOUT=30000

# -----------------------------------------------------------------------------
# REDIS (Cache y Sesiones)
# -----------------------------------------------------------------------------
REDIS_ENABLED=false
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_URL=redis://localhost:6379/0

# -----------------------------------------------------------------------------
# JWT
# -----------------------------------------------------------------------------
JWT_SECRET=violet-erp-super-secret-jwt-key-change-in-production-2024
JWT_EXPIRES_IN=1h
JWT_REFRESH_SECRET=violet-erp-super-secret-refresh-key-change-in-production-2024
JWT_REFRESH_EXPIRES_IN=7d
JWT_ISSUER=violet-erp
JWT_AUDIENCE=violet-erp-users

# -----------------------------------------------------------------------------
# SEGURIDAD
# -----------------------------------------------------------------------------
BCRYPT_ROUNDS=12
SESSION_SECRET=violet-session-secret-change-in-production-2024
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_AUTH_WINDOW_MS=900000
RATE_LIMIT_AUTH_MAX_REQUESTS=10

# -----------------------------------------------------------------------------
# LOGS
# -----------------------------------------------------------------------------
LOG_LEVEL=debug
LOG_FILE=./logs/app.log
LOG_MAX_SIZE=10m
LOG_MAX_FILES=30d
LOG_HTTP_ENABLED=true

# -----------------------------------------------------------------------------
# WEBSOCKETS
# -----------------------------------------------------------------------------
WS_ENABLED=true
WS_PORT=3001
WS_CORS_ORIGIN=http://localhost:5173

# -----------------------------------------------------------------------------
# ARCHIVOS
# -----------------------------------------------------------------------------
UPLOAD_PATH=./uploads
UPLOAD_MAX_SIZE=10485760
UPLOAD_ALLOWED_EXTENSIONS=jpg,jpeg,png,pdf,xlsx,xls,csv,doc,docx,zip

# -----------------------------------------------------------------------------
# CORREO ELECTRÓNICO
# -----------------------------------------------------------------------------
MAIL_ENABLED=false
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=tu-email@gmail.com
MAIL_PASSWORD=tu-app-password
MAIL_FROM=Violet ERP <noreply@violet-erp.com>
MAIL_SECURE=false
MAIL_TLS_REJECT_UNAUTHORIZED=false

# -----------------------------------------------------------------------------
# SENTRY (Monitoreo de Errores)
# -----------------------------------------------------------------------------
SENTRY_ENABLED=false
SENTRY_DSN=https://tu-dsn@sentry.io/proyecto
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1

# -----------------------------------------------------------------------------
# CARACTERÍSTICAS OPCIONALES
# -----------------------------------------------------------------------------
FEATURE_EMAIL_VERIFICATION=false
FEATURE_TWO_FACTOR_AUTH=false
FEATURE_SOCIAL_LOGIN=false
FEATURE_FILE_STORAGE_LOCAL=true
FEATURE_FILE_STORAGE_S3=false
FEATURE_CACHE_REDIS=false
FEATURE_REALTIME=true
FEATURE_AUDIT_LOG=true

# -----------------------------------------------------------------------------
# AWS S3 (Almacenamiento de Archivos)
# -----------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=violet-erp-files
AWS_S3_ENDPOINT=

# -----------------------------------------------------------------------------
# STRIPE (Pagos)
# -----------------------------------------------------------------------------
STRIPE_ENABLED=false
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# -----------------------------------------------------------------------------
# FRONTEND (Vite)
# -----------------------------------------------------------------------------
VITE_APP_NAME=Violet ERP
VITE_API_URL=http://localhost:3000/api
VITE_WS_URL=ws://localhost:3001
VITE_CLOUD_API_URL=https://api.violet-erp.com
VITE_APP_VERSION=2.0.0
VITE_SENTRY_DSN=
VITE_ENABLE_DEVTOOLS=true

# -----------------------------------------------------------------------------
# CARACTERÍSTICAS DEL FRONTEND
# -----------------------------------------------------------------------------
VITE_FEATURE_DARK_MODE=true
VITE_FEATURE_NOTIFICATIONS=true
VITE_FEATURE_REAL_TIME=true
VITE_FEATURE_OFFLINE_MODE=true
VITE_FEATURE_PWA=false
VITE_FEATURE_ANALYTICS=false

# -----------------------------------------------------------------------------
# PM2 (Producción)
# -----------------------------------------------------------------------------
PM2_INSTANCES=4
PM2_MAX_MEMORY=1G
PM2_RESTART_DELAY=4000

# -----------------------------------------------------------------------------
# BACKUP AUTOMÁTICO
# -----------------------------------------------------------------------------
BACKUP_ENABLED=true
BACKUP_INTERVAL=86400000
BACKUP_RETENTION=30
BACKUP_PATH=./backups
