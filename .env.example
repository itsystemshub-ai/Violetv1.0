# Violet ERP - Variables de Entorno

# Aplicación
NODE_ENV=development
APP_NAME=Violet ERP
APP_VERSION=1.0.0

# Servidor
PORT=3000
HOST=localhost
CORS_ORIGIN=http://localhost:5173

# Firebird
FIREBIRD_HOST=localhost
FIREBIRD_PORT=3050
FIREBIRD_DATABASE=C:/VioletERP/database/valery3.fdb
FIREBIRD_USER=SYSDBA
FIREBIRD_PASSWORD=masterkey

# JWT
JWT_SECRET=violet-erp-secret-change-in-production
JWT_EXPIRES_IN=1h
JWT_REFRESH_SECRET=violet-erp-refresh-secret-change-in-production
JWT_REFRESH_EXPIRES_IN=7d

# Seguridad
BCRYPT_ROUNDS=10

# Logs
LOG_LEVEL=debug
LOG_FILE=./logs/app.log
