# =============================================================================
# VIOLET ERP MONOREPO - Environment Variables
# =============================================================================
# Copy this file as .env and fill in your actual values.
# NEVER commit the .env file to Git!
# =============================================================================

# -----------------------------------------------------------------------------
# STITCH PRO CONFIGURATION
# -----------------------------------------------------------------------------
VITE_STITCH_MODE=premium
VITE_STITCH_HUD_ENABLED=true

# -----------------------------------------------------------------------------
# N8N WORKFLOW AUTOMATION
# -----------------------------------------------------------------------------
VITE_N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook
VITE_N8N_API_KEY=your_optional_api_key

# -----------------------------------------------------------------------------
# EMAIL SERVICE (RESEND)
# Free tier: 3,000 emails/month
# Register: https://resend.com
# -----------------------------------------------------------------------------
VITE_RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# -----------------------------------------------------------------------------
# WHATSAPP SERVICE (CALLMEBOT)
# Free API for WhatsApp messages
# Setup: https://www.callmebot.com/blog/free-api-whatsapp-messages/
# -----------------------------------------------------------------------------
VITE_CALLMEBOT_APIKEY=xxxxxxx

# -----------------------------------------------------------------------------
# AI PROVIDERS - SELF-HEALING IA
# -----------------------------------------------------------------------------

# Groq AI (Primary) - Llama 3, ultra-fast
# Free tier: 14,400 requests/day
# Register: https://console.groq.com
VITE_GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Gemini 2.0 Flash (Fallback) - Long context
# Free tier: 1,500 requests/day
# Register: https://aistudio.google.com/apikey
VITE_GEMINI_API_KEY=AIzaXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Hugging Face (Last Resort) - Mistral 7B
# Free with account
# Register: https://huggingface.co/settings/tokens
VITE_HUGGINGFACE_API_KEY=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# -----------------------------------------------------------------------------
# FREE APIs (NO API KEY REQUIRED)
# -----------------------------------------------------------------------------
# - pydolarve.org (BCV Exchange Rate)
# - Nominatim / OpenStreetMap (Address Geocoding)
# - Open Food Facts (Barcode Lookup)
# - Open-Meteo (Weather)
# - SubtleCrypto (Checksum) - Native browser/Electron API

# -----------------------------------------------------------------------------
# SECURITY & AUTHENTICATION
# -----------------------------------------------------------------------------

# JWT Secret - Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
VITE_JWT_SECRET=your-super-secret-key-min-32-characters-long-change-in-production
JWT_EXPIRES_IN=24h
JWT_REFRESH_SECRET=another-different-secret-for-refresh-tokens
JWT_REFRESH_EXPIRES_IN=7d

# Bcrypt Configuration
BCRYPT_ROUNDS=12

# -----------------------------------------------------------------------------
# DEMO / DEVELOPMENT USERS
# -----------------------------------------------------------------------------
# Enable mock users for demo (true/false)
# In production, set to 'false' and use real database
VITE_ENABLE_MOCK_USERS=true

# Super Admin Credentials (development/demo only)
VITE_SUPER_ADMIN_USER=superadmin
VITE_SUPER_ADMIN_PASS=Violet@2026!

# -----------------------------------------------------------------------------
# SERVER CONFIGURATION
# -----------------------------------------------------------------------------
PORT=3001
HOST=localhost

# -----------------------------------------------------------------------------
# DATABASE CONFIGURATION
# -----------------------------------------------------------------------------
# SQLite (Local)
DATABASE_PATH=./violet_erp.db

# PostgreSQL (Production - Optional)
# DATABASE_URL=postgresql://user:password@localhost:5432/violet_erp

# Supabase (Optional)
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=your-anon-key

# -----------------------------------------------------------------------------
# APP CONFIGURATION
# -----------------------------------------------------------------------------
NODE_ENV=development
VITE_API_URL=http://localhost:3001
