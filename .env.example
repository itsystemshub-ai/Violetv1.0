# =============================================================================
# VIOLET ERP - Variables de Entorno Híbridas
# =============================================================================

# -----------------------------------------------------------------------------
# APLICACIÓN
# -----------------------------------------------------------------------------
NODE_ENV=development
APP_NAME=Violet ERP
APP_VERSION=2.0.0

# -----------------------------------------------------------------------------
# MODO HÍBRIDO
# -----------------------------------------------------------------------------
# Opciones: local, cloud, hybrid
HYBRID_MODE=hybrid

# Rol del nodo: master, slave, standalone
HYBRID_NODE_ROLE=standalone

# ¿Es este nodo el maestro? (true/false)
HYBRID_IS_MASTER=false

# ID único del nodo (auto-generado si no se especifica)
HYBRID_NODE_ID=

# URL de la API cloud (para nodos slaves)
HYBRID_CLOUD_API_URL=http://localhost:3000

# URL del WebSocket cloud (para nodos slaves)
HYBRID_CLOUD_WS_URL=ws://localhost:3001

# URL de la API local (para acceso directo)
HYBRID_LOCAL_API_URL=http://localhost:3000

# API Key para comunicación entre nodos
HYBRID_API_KEY=cambia-esto-en-produccion

# Intervalo de sincronización (ms)
HYBRID_SYNC_INTERVAL=15000

# Tamaño de lote para sync
HYBRID_SYNC_BATCH_SIZE=20

# Máximos reintentos para sync fallido
HYBRID_SYNC_MAX_RETRIES=5

# -----------------------------------------------------------------------------
# SERVIDOR
# -----------------------------------------------------------------------------
PORT=3000
HOST=0.0.0.0
CORS_ORIGIN=*
CORS_CREDENTIALS=false

# -----------------------------------------------------------------------------
# FIREBIRD DATABASE
# -----------------------------------------------------------------------------
FIREBIRD_HOST=localhost
FIREBIRD_PORT=3050
FIREBIRD_DATABASE=C:/VioletERP/database/valery3.fdb
FIREBIRD_USER=SYSDBA
FIREBIRD_PASSWORD=masterkey
FIREBIRD_ROLE=RDB$ADMIN
FIREBIRD_PAGE_SIZE=4096

# Pool de conexiones
FIREBIRD_POOL_MIN=2
FIREBIRD_POOL_MAX=10
FIREBIRD_POOL_ACQUIRE_TIMEOUT=5000
FIREBIRD_POOL_IDLE_TIMEOUT=30000

# -----------------------------------------------------------------------------
# SQLITE LOCAL (para caché y offline)
# -----------------------------------------------------------------------------
SQLITE_ENABLED=true
SQLITE_PATH=./data/violet_local.db
SQLITE_JOURNAL_MODE=WAL

# -----------------------------------------------------------------------------
# JWT
# -----------------------------------------------------------------------------
JWT_SECRET=violet-erp-super-secret-jwt-key-change-in-production-2026-min-64-chars
JWT_EXPIRES_IN=24h
JWT_REFRESH_SECRET=violet-erp-super-secret-refresh-key-change-in-production-2026-min-64-chars
JWT_REFRESH_EXPIRES_IN=7d
JWT_ISSUER=violet-erp
JWT_AUDIENCE=violet-erp-users

# -----------------------------------------------------------------------------
# SEGURIDAD
# -----------------------------------------------------------------------------
BCRYPT_ROUNDS=12
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_AUTH_WINDOW_MS=900000
RATE_LIMIT_AUTH_MAX_REQUESTS=10

# -----------------------------------------------------------------------------
# LOGS
# -----------------------------------------------------------------------------
LOG_LEVEL=info
LOG_FILE=./logs/app.log
LOG_MAX_SIZE=10m
LOG_MAX_FILES=30
LOG_HTTP_ENABLED=true

# -----------------------------------------------------------------------------
# WEBSOCKETS
# -----------------------------------------------------------------------------
WS_ENABLED=true
WS_PORT=3001
WS_CORS_ORIGIN=*

# -----------------------------------------------------------------------------
# ARCHIVOS
# -----------------------------------------------------------------------------
UPLOAD_PATH=./uploads
UPLOAD_MAX_SIZE=10485760
UPLOAD_ALLOWED_EXTENSIONS=jpg,jpeg,png,pdf,xlsx,xls,csv,doc,docx,zip

# -----------------------------------------------------------------------------
# CORREO ELECTRÓNICO
# -----------------------------------------------------------------------------
MAIL_ENABLED=false
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=
MAIL_PASSWORD=
MAIL_FROM=Violet ERP <noreply@violet-erp.com>

# -----------------------------------------------------------------------------
# CARACTERÍSTICAS OPCIONALES
# -----------------------------------------------------------------------------
FEATURE_EMAIL_VERIFICATION=false
FEATURE_TWO_FACTOR_AUTH=false
FEATURE_SOCIAL_LOGIN=false
FEATURE_FILE_STORAGE_LOCAL=true
FEATURE_REALTIME=true
FEATURE_AUDIT_LOG=true
FEATURE_OFFLINE_MODE=true

# -----------------------------------------------------------------------------
# FRONTEND (Vite)
# -----------------------------------------------------------------------------
VITE_APP_NAME=Violet ERP
VITE_API_URL=http://localhost:3000
VITE_WS_URL=ws://localhost:3001
VITE_APP_VERSION=2.0.0

# Modo híbrido frontend
VITE_HYBRID_MODE=hybrid
VITE_AUTO_SYNC=true
VITE_SYNC_INTERVAL=15000
VITE_SYNC_MAX_RETRIES=5

# Características del frontend
VITE_FEATURE_DARK_MODE=true
VITE_FEATURE_NOTIFICATIONS=true
VITE_FEATURE_REALTIME=true
VITE_FEATURE_OFFLINE_MODE=true

# Locale y timezone
VITE_APP_LOCALE=es-DO
VITE_APP_TIMEZONE=America/Santo_Domingo

# -----------------------------------------------------------------------------
# ADMIN USER (First Run)
# -----------------------------------------------------------------------------
ADMIN_USERNAME=admin
ADMIN_PASSWORD=Violet@2026!
ADMIN_EMAIL=admin@violet-erp.com
