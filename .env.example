# .env.example — Variables de entorno para Violet ERP
# Copia este archivo como ".env" y completa los valores reales.
# NUNCA subas el archivo .env real a Git.

# ── API 2: Resend (Email transaccional) ──────────────────────────────────────
# Regístrate gratis en https://resend.com — 3,000 emails/mes
VITE_RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# ── API 4: CallMeBot (WhatsApp) ───────────────────────────────────────────────
# Sigue las instrucciones en https://www.callmebot.com/blog/free-api-whatsapp-messages/
VITE_CALLMEBOT_APIKEY=xxxxxxx

# ── Self-Healing IA — Provider Primario ──────────────────────────────────────
# API 6: Groq AI (Llama 3, ultra-rápido) — 14,400 req/día gratis
# Regístrate en https://console.groq.com
VITE_GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Self-Healing IA — Provider Fallback ──────────────────────────────────────
# Gemini 2.0 Flash — 1,500 req/día gratis, contexto largo
# Regístrate en https://aistudio.google.com/apikey
VITE_GEMINI_API_KEY=AIzaXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── Self-Healing IA — Último Recurso ─────────────────────────────────────────
# Hugging Face (Mistral 7B) — gratis con cuenta
# Regístrate en https://huggingface.co/settings/tokens
VITE_HUGGINGFACE_API_KEY=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── NOTAS sobre APIs sin API key ─────────────────────────────────────────────
# pydolarve.org (Tasa BCV) — Sin key, gratis
# Nominatim / OpenStreetMap (Direcciones) — Sin key, gratis
# Open Food Facts (Barcode) — Sin key, gratis
# Open-Meteo (Clima) — Sin key, gratis
# SubtleCrypto (Checksum) — Nativa del navegador/Electron, sin key

# ── Seguridad y Autenticación ────────────────────────────────────────────────
# JWT Secret - Generar con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
VITE_JWT_SECRET=your-super-secret-key-min-32-characters-long-change-in-production
JWT_EXPIRES_IN=24h
JWT_REFRESH_SECRET=another-different-secret-for-refresh-tokens
JWT_REFRESH_EXPIRES_IN=7d

# Bcrypt Configuration
BCRYPT_ROUNDS=12

# ── Demo/Development Users ───────────────────────────────────────────────────
# Habilitar usuarios mock para demo (true/false)
# En producción, establecer en 'false' y usar base de datos real
VITE_ENABLE_MOCK_USERS=true

# Super Admin Credentials (solo para desarrollo/demo)
VITE_SUPER_ADMIN_USER=superadmin
VITE_SUPER_ADMIN_PASS=Violet@2026!
